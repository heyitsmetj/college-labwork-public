<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background color -->
    <solid android:color="#5A5AE6"/>

    <!-- Border -->
    <stroke
        android:width="4dp"
        android:color="#FFFFFF"/>

    <!-- Rounded corners -->
    <corners android:radius="12dp"/>

    <!-- Padding inside -->
    <padding
        android:left="20dp"
        android:right="20dp"
        android:top="20dp"
        android:bottom="20dp"/>
</shape>